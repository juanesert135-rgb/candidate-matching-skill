          "name": "n8n free OpenAI API credits"
        }
      }
    },
    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"candidate_name\": \"John Doe\",\n  \"years_experience\": 7,\n  \"skills\": [\n    \"Python\",\n    \"AWS\",\n    \"Docker\"\n  ],\n  \"education\": \"BS Computer Science\",\n  \"previous_roles\": [\n    \"Senior Developer\",\n    \"Software Engineer\"\n  ]\n}"
      },
      "id": "1589e4fd-e6ca-46df-a320-555629f20170",
      "name": "Resume Parser Schema",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        2176,
        480
